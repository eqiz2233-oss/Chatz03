# Chatz environment variables.
# ────────────────────────────────────────────────────────────────────────────
# Copy this to ".env" for local dev, or paste each KEY into Railway Variables
# for production. NEVER paste the entire "KEY=value" line into Railway's
# value field — the value goes alone (no key prefix, no quotes).
#
# Each var below lists:
#   • what feature it controls
#   • whether it's required at launch (REQUIRED) or optional (optional)
#   • where to get the value
# ────────────────────────────────────────────────────────────────────────────


# ═══ Database ═══════════════════════════════════════════════════════════════
# REQUIRED for production. Railway provides this automatically when you add
# the Postgres add-on. Without it, the app falls back to a JSON file in
# RAILWAY_VOLUME_MOUNT_PATH which is fine for dev but loses data on redeploy.
DATABASE_URL=


# ═══ Server ═════════════════════════════════════════════════════════════════
# REQUIRED for production: enables Secure cookies + skips dev-only fallbacks.
NODE_ENV=production

# Optional. Override the auto-detected public origin. Set this if your
# domain is fronted by a CDN that strips X-Forwarded-Host headers (e.g.
# Cloudflare with non-default rules). Used for OAuth redirect URIs.
# Example: PUBLIC_BASE_URL=https://chatz.example.com
PUBLIC_BASE_URL=

# Optional. Listen port — Railway sets PORT automatically; only set if you
# need a non-default for local dev.
# PORT=8787


# ═══ First-time owner seed ═══════════════════════════════════════════════════
# Optional. On a completely fresh database (empty users table), Chatz seeds
# one admin account using these. Default username is "admin" with password
# "admin" — change the password before exposing to the internet.
OWNER_USERNAME=admin
OWNER_PASSWORD=

# Optional / reserved. Not currently read by code, but the var slot exists
# for future signed-session use; safe to set a long random string ahead of
# time so we don't have to rotate sessions when we wire it up.
SESSION_SECRET=


# ═══ AI auto-reply ═══════════════════════════════════════════════════════════
# REQUIRED for AI bot replies. Set EITHER OpenAI OR Anthropic — having only
# one is fine; the code auto-picks based on which key is present.
#
# AI_PROVIDER is optional and only matters if you set BOTH keys and want to
# force a specific one ("openai" or "anthropic").
AI_PROVIDER=openai

# OpenAI ChatGPT path (recommended — cheaper, fast).
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional override. Defaults: gpt-4o-mini for OpenAI, claude-opus-4-7 for
# Anthropic. Use gpt-4o for higher quality at ~10× the cost.
# AI_MODEL=gpt-4o-mini

# Anthropic Claude path (alternative — better Thai nuance, higher cost).
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Anthropic-only. Controls how much "thinking" Claude does:
# low | medium | high | xhigh | max. Default: medium.
# AI_EFFORT=medium


# ═══ Email (Resend) ═════════════════════════════════════════════════════════
# REQUIRED for password reset + Settings → "ส่งอีเมลยืนยัน" to actually
# deliver. Without RESEND_API_KEY the email body is logged to server stdout
# instead of being sent — useful for dev, not for production.
#
# Get a key at: https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=

# REQUIRED if RESEND_API_KEY is set. The "From:" header.
# Format: "Chatz <noreply@yourdomain.com>" — domain must be verified in Resend.
EMAIL_FROM=Chatz <onboarding@resend.dev>


# ═══ Facebook + Instagram Messaging ═════════════════════════════════════════
# OPTIONAL but recommended. Without these the FB / IG channels just stay
# disconnected in Settings — the rest of Chatz still works.
#
# Get values at: https://developers.facebook.com → your App
#   • Settings → Basic            → FB_APP_ID, FB_APP_SECRET
#   • Webhooks → Page (subscribe) → FB_VERIFY_TOKEN (you invent the string)
#
# ⚠️  FB_APP_ID must be DIGITS ONLY. Do NOT paste "FB_APP_ID=1620000000".
FB_APP_ID=
FB_APP_SECRET=
FB_VERIFY_TOKEN=

# Optional. Legacy single-page token. Used as fallback when no Page is
# OAuth-connected in Settings. Connecting a Page via the UI is preferred.
FB_PAGE_ACCESS_TOKEN=

# Optional. Pin the Graph API version. Update once a year as Meta deprecates.
FB_GRAPH_VERSION=v21.0


# ═══ LINE Messaging (LINE Official Account) ═════════════════════════════════
# Two routes — pick one:
#
# Route A (recommended for SaaS): LINE Module Channel.
#   Operator registers ONE Module Channel; every Chatz shop owner clicks
#   "เชื่อมต่อด้วย LINE" and connects their own OA via OAuth — no token
#   pasting needed. Apply at: https://developers.line.biz → Module Channel
LINE_MODULE_CHANNEL_ID=
LINE_MODULE_CHANNEL_SECRET=
#
# Route B (single-OA / fallback): paste a Messaging API channel's secret +
# long-lived access token. This works for a single shop but doesn't scale
# to a multi-shop deployment. Shop owners can paste these via
# Settings → Integrations → "ตั้งค่าขั้นสูง" without setting env at all.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=


# ═══ LINE Login (sign in with LINE) ════════════════════════════════════════
# OPTIONAL. Adds the green LINE chip to /login + /register. Without these
# the LINE button still renders but tapping it shows a "not configured"
# toast. This is a separate channel from Module Channel above (same LINE
# Developers console, different channel type).
#
# Apply at: https://developers.line.biz → New channel → "LINE Login"
# Set Callback URL to: https://<your-domain>/api/auth/oauth/line/callback
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=


# ═══ Google Sign-In ══════════════════════════════════════════════════════════
# OPTIONAL. Adds the colored Google G chip to /login + /register.
# Get the client ID at: https://console.cloud.google.com
#   APIs & Services → Credentials → Create credentials → OAuth client ID
#   Application type: "Web application"
#   Authorized JavaScript origins: https://<your-domain>
#   Authorized redirect URIs: (none needed — GSI uses the JS library)
#
# The CLIENT_ID alone is enough — GSI does token verification on its side.
# CLIENT_SECRET is unused by the current code; safe to leave set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ═══ EasySlip (Thai payment-slip verification) ══════════════════════════════
# OPTIONAL. Without EASYSLIP_TOKEN, customer-sent slip images don't get
# auto-verified — they're still saved to the inbox, the admin just has to
# eyeball them. Get a key at: https://easyslip.com
EASYSLIP_TOKEN=

# Optional. Default v2. Only set this to "v1" if you have a legacy key.
# EASYSLIP_API_VERSION=v2


# ═══ Railway-specific ═══════════════════════════════════════════════════════
# Set automatically by Railway when you mount a volume — points at the
# writable storage location for the JSON fallback store. Safe to leave
# unset unless you specifically need to override.
# RAILWAY_VOLUME_MOUNT_PATH=
