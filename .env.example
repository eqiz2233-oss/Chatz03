# LINE (optional — inbox + reply)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Server
BACKEND_PORT=8787
# Production: your public URL (OAuth redirect, links)
PUBLIC_BASE_URL=

# Facebook / Instagram (Meta)
# FB_VERIFY_TOKEN — random string; same value in Meta webhook “Verify Token”
FB_VERIFY_TOKEN=
# FB_PAGE_ACCESS_TOKEN — Page access token (send replies, fetch names). From Meta or after Connect.
FB_PAGE_ACCESS_TOKEN=
# FB_APP_ID + FB_APP_SECRET — from https://developers.facebook.com → your App → Settings → Basic (needed for “Connect” button / OAuth)
FB_APP_ID=1627384615027232
FB_APP_SECRET=
FB_GRAPH_VERSION=v21.0

EASYSLIP_TOKEN=735c87ef-93f2-4326-b692-0c9d991a05ab
